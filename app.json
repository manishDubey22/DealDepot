{
  "expo": {
    "name": "MADR Checker",
    "slug": "madr-checker",
    "icon": "./assets/icons/wholeSeller/Logo.jpg",
    "jsEngine": "hermes",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/icons/wholeSeller/Logo.jpg",
      "backgroundColor": "#AEDC81",
      "resizeMode": "contain"
    },
    "experiments": {
      "newArchEnabled": true
    },
    "android": {
      "newArchEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/wholeSeller/Logo.jpg",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.madrchecker.app"
    },
    "ios": {
      "newArchEnabled": false
    },
    "extra": {
      "eas": {
        "projectId": "6e01e053-a911-4d09-ae74-85a366f92b46"
      }
    },
    "owner": "madr.checker"
  }
}
